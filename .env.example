# Copy this file to .env and fill in real values before running locally.
# ALL vars are REQUIRED — missing vars activate placeholder mode or throw at runtime.
# Get Supabase values from your project dashboard.
# Get Stripe values from the Stripe dashboard.
# Get Upstash values from the Upstash console (required for rate limiting in api/go-respond.js).
# Get Deepgram values from the Deepgram console.

VITE_SUPABASE_URL=PASTE_YOUR_SUPABASE_URL_HERE
VITE_SUPABASE_ANON_KEY=PASTE_YOUR_SUPABASE_ANON_KEY_HERE
VITE_STRIPE_PUBLISHABLE_KEY=PASTE_YOUR_STRIPE_PUBLISHABLE_KEY_HERE
VITE_DEEPGRAM_API_KEY=PASTE_YOUR_DEEPGRAM_API_KEY_HERE

# Required for cross-instance rate limiting (Upstash Redis)
UPSTASH_REDIS_REST_URL=PASTE_YOUR_UPSTASH_REDIS_REST_URL_HERE
UPSTASH_REDIS_REST_TOKEN=PASTE_YOUR_UPSTASH_REDIS_REST_TOKEN_HERE
